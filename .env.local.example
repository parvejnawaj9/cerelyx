# ----------------------------------------------------------------------------
# Cerelyx environment configuration
# Copy this file to `.env.local` and adjust. `.env.local` is gitignored.
#
# Two ways to run:
#   (A) Emulators (default below) — fast, free, offline. No real project touched.
#   (B) Real "cerelyx" project — set NEXT_PUBLIC_USE_FIREBASE_EMULATORS=0 and use
#       the real values shown in the comments, plus a service-account key.
# ----------------------------------------------------------------------------

# Root domain (incl. port in dev). Local dev: lvh.me:3000. Production: cerelyx.online
NEXT_PUBLIC_ROOT_DOMAIN=lvh.me:3000

# "1" → connect both SDKs to the local Firebase Emulator Suite (recommended for dev).
NEXT_PUBLIC_USE_FIREBASE_EMULATORS=1

# ----------------------------------------------------------------------------
# Firebase Web (client) config.
#   Emulator dev: the project id "demo-cerelyx" keeps the emulators fully offline.
#   Real project: replace with the "cerelyx" values below.
# ----------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=demo-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=demo-cerelyx.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=demo-cerelyx
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=demo-cerelyx.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000
# NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Real "cerelyx" web config (for B / production reference):
#   NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyBnCdcAmX-nx-pCY9RAPQ9qr5Hp1SrfYV8
#   NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=cerelyx.firebaseapp.com
#   NEXT_PUBLIC_FIREBASE_PROJECT_ID=cerelyx
#   NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=cerelyx.firebasestorage.app
#   NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=1076162267893
#   NEXT_PUBLIC_FIREBASE_APP_ID=1:1076162267893:web:3bc9738de693f9da1d53bc
#   NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-JXGRQLQKBV

# ----------------------------------------------------------------------------
# Firebase Admin (server) config.
#   Emulator dev: only the project id is needed (matches the emulator project).
#   Real project locally: set GOOGLE_APPLICATION_CREDENTIALS or FIREBASE_SERVICE_ACCOUNT_KEY.
#   On App Hosting: Application Default Credentials are automatic — leave unset.
# ----------------------------------------------------------------------------
FIREBASE_PROJECT_ID=demo-cerelyx
# FIREBASE_SERVICE_ACCOUNT_KEY=
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Secret for signing guest-access cookies (private sites). Any long random string
# in dev; in production set it as an App Hosting secret (see apphosting.yaml).
ACCESS_TOKEN_SECRET=dev-access-secret-change-me

# Emulator host ports (defaults match firebase.json).
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
FIREBASE_STORAGE_EMULATOR_HOST=127.0.0.1:9199
